@page "/"
@using SmartPotsWeb.Data
@using SmartPotsWeb.Models
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.SignalR.Client
@inject AppDbContext Db
@inject NavigationManager Nav
@implements IAsyncDisposable
@rendermode InteractiveServer

<PageTitle>Smart Pots — Панель керування</PageTitle>

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>🌱 Мої рослини <small class="text-muted fs-6">(@(hubConnection?.State == HubConnectionState.Connected ? "Live" : "Connecting..."))</small></h1>
        <button class="btn btn-outline-primary btn-sm" @onclick="LoadDataFromDb">
            🔄 Оновити з бази
        </button>
    </div>

    @if (lastTelemetry == null)
    {
        <div class="alert alert-info">
            🛰 Даних від хаба ще не надходило. Очікуємо першого підключення...
        </div>
    }
    else
    {
        <div class="row">
            <div class="col-md-4 mb-4">
                <div class="card shadow-sm border-primary">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">🏠 Стан Хаба</h5>
                    </div>
                    <div class="card-body">
                        <p class="mb-1"><strong>🌡 Температура:</strong> @lastTelemetry.Temp.ToString("F1") °C</p>
                        <p class="mb-1"><strong>💧 Вологість:</strong> @lastTelemetry.Hum.ToString("F1") %</p>
                        <p class="mb-1"><strong>☀️ Світло:</strong> @lastTelemetry.Lux lux</p>
                        <p class="mb-0">
                            <strong>💡 Лампа:</strong>
                            <span class="badge @(lastTelemetry.LightOn ? "bg-success" : "bg-secondary")">
                                @(lastTelemetry.LightOn ? "Увімкнено" : "Вимкнено")
                            </span>
                        </p>
                        <hr />
                        <small class="text-muted">Оновлено: @lastTelemetry.RecordedAt.ToLocalTime().ToString("HH:mm:ss")</small>
                    </div>
                </div>
            </div>

            @* Блок горщиків *@
            <div class="col-md-8">
                <div class="row">
                    @foreach (var pot in lastTelemetry.Pots)
                    {
                        <div class="col-sm-6 mb-3">
                            <div class="card h-100 shadow-sm border-0 bg-light">
                                <div class="card-body">
                                    <div class="d-flex justify-content-between">
                                        <h6 class="card-title text-secondary">
                                            @(GetPotName(pot.HardwareId))
                                        </h6>
                                        @if (pot.Moisture < pot.Target - 5)
                                        {
                                            <span class="badge bg-warning text-dark">Потрібен полив</span>
                                        }
                                    </div>
                                    <div class="d-flex align-items-center mt-2">
                                        <div class="display-6 me-3">🚿</div>
                                        <div class="flex-grow-1">
                                            <div class="progress mb-2" style="height: 20px; border-radius: 10px;">
                                                <div class="progress-bar progress-bar-striped progress-bar-animated @(pot.Moisture < 30 ? "bg-danger" : "bg-info")"
                                                     role="progressbar"
                                                     style="width: @(pot.Moisture)%">
                                                    @pot.Moisture%
                                                </div>
                                            </div>
                                            <div class="d-flex justify-content-between">
                                                <small class="text-muted">Ціль: @pot.Target%</small>
                                                <small class="fw-bold @(pot.Moisture >= pot.Target ? "text-success" : "text-primary")">
                                                    @(pot.Moisture >= pot.Target ? "OK" : "П'є...")
                                                </small>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
</div>

@code {
    private HubTelemetry? lastTelemetry;
    private HubConnection? hubConnection;

    private Dictionary<int, string> potNames = new();

    protected override async Task OnInitializedAsync()
    {
        var pots = await Db.Pots.Where(p => p.HardwareId.HasValue).ToListAsync();
        foreach(var p in pots) {
			if (p.HardwareId.HasValue)
                potNames[p.HardwareId.Value] = p.Name ?? "Без імені";
        }

        await LoadDataFromDb();

        hubConnection = new HubConnectionBuilder()
            .WithUrl(Nav.ToAbsoluteUri("/telemetryHub"))
            .WithAutomaticReconnect()
            .Build();

        hubConnection.On<HubTelemetry>("ReceiveTelemetryUpdate", (data) =>
        {
            lastTelemetry = data;
            InvokeAsync(StateHasChanged);
        });

        await hubConnection.StartAsync();
    }

    private string GetPotName(int hardwareId) =>
        potNames.TryGetValue(hardwareId, out var name) ? name : "Невідомий горщик";

    private async Task LoadDataFromDb()
    {
        lastTelemetry = await Db.HubTelemetries
            .Include(h => h.Pots)
            .OrderByDescending(h => h.RecordedAt)
            .FirstOrDefaultAsync();
    }

    public async ValueTask DisposeAsync()
    {
        if (hubConnection is not null)
            await hubConnection.DisposeAsync();
    }
}