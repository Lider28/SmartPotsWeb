@page "/stats/{HardwareId:int}"
@rendermode InteractiveServer
@using Radzen.Blazor
@using SmartPotsWeb.Data
@using Microsoft.EntityFrameworkCore
@using SmartPotsWeb.Models
@inject AppDbContext Db

<PageTitle>Статистика горщика</PageTitle>

<div class="container mt-4">
	<h2>📊 Статистика (Порт @HardwareId)</h2>
	<p class="text-muted">Дані за поточну добу</p>

	@if (chartData == null)
	{
		<div class="d-flex justify-content-center mt-5">
			<div class="spinner-border text-success" role="status">
				<span class="visually-hidden">Завантаження...</span>
			</div>
		</div>
	}
	else if (!chartData.Any())
	{
		<div class="alert alert-warning">Немає даних телеметрії для цього порту за обраний період.</div>
	}
	else
	{
		<div class="card shadow-sm mb-4">
			<div class="card-header bg-white">
				<h5 class="mb-0">💧 Вологість ґрунту</h5>
			</div>
			<div class="card-body">
				<RadzenChart>
					<RadzenLineSeries Data="@chartData"
									  CategoryProperty="Timestamp"
									  Title="Реальна вологість"
									  ValueProperty="Moisture"
									  Stroke="#0d6efd"
									  Smooth="true" />
                                      
					<RadzenLineSeries Data="@chartData"
									  CategoryProperty="Timestamp"
									  Title="Цільова вологість"
									  ValueProperty="TargetMoisture"
									  Stroke="#dc3545"
									  LineType="LineType.Dashed" />

					<RadzenCategoryAxis Padding="20" FormatString="{0:HH:mm}">
						<RadzenAxisTitle Text="Час" />
					</RadzenCategoryAxis>
                    
					<RadzenValueAxis Min="0" Max="100">
						<RadzenGridLines Visible="true" />
						<RadzenAxisTitle Text="Вологість %" />
					</RadzenValueAxis>
                    
					<RadzenLegend Position="LegendPosition.Bottom" />
				</RadzenChart>
			</div>
		</div>

		<div class="card shadow-sm mb-4">
			<div class="card-header bg-white">
				<h5 class="mb-0">🌡 Мікроклімат (Хаб)</h5>
			</div>
			<div class="card-body">
				<RadzenChart>
					<RadzenLineSeries Data="@chartData"
									  CategoryProperty="Timestamp"
									  Title="Температура (°C)"
									  ValueProperty="HubTemp"
									  Stroke="#fd7e14" />
                                      
					<RadzenLineSeries Data="@chartData"
									  CategoryProperty="Timestamp"
									  Title="Вологість повітря (%)"
									  ValueProperty="HubHum"
									  Stroke="#20c997" />

					<RadzenCategoryAxis Padding="20" FormatString="{0:HH:mm}" />
					<RadzenValueAxis>
						<RadzenGridLines Visible="true" />
					</RadzenValueAxis>
                    
					<RadzenLegend Position="LegendPosition.Bottom" />
				</RadzenChart>
			</div>
		</div>

		<div class="card shadow-sm mb-5">
			<div class="card-header bg-white d-flex justify-content-between align-items-center">
				<h5 class="mb-0">☀️ Освітлення</h5>
				<span class="badge bg-warning text-dark fs-6 shadow-sm">
					Накопичено: @chartData.Last().DailyLuxHours.ToString("F0") lx*h
				</span>
			</div>
			<div class="card-body">
				<RadzenChart>
					<RadzenLineSeries Data="@chartData"
									  CategoryProperty="Timestamp"
									  Title="Освітленість (lx)"
									  ValueProperty="HubLux"
									  Stroke="#ffc107"
									  Smooth="true" />

					<RadzenCategoryAxis Padding="20" FormatString="{0:HH:mm}" />
					<RadzenValueAxis>
						<RadzenGridLines Visible="true" />
					</RadzenValueAxis>
                    
					<RadzenLegend Position="LegendPosition.Bottom" />
				</RadzenChart>
			</div>
		</div>
	}
</div>

@code {
	[Parameter]
	public int HardwareId { get; set; }

	private List<PotChartPoint>? chartData;

	protected override async Task OnInitializedAsync()
	{
		try
		{
			var todayDate = DateOnly.FromDateTime(DateTime.UtcNow);

			var history = await Db.HubTelemetries
				.AsNoTracking()
				.Where(h => h.RecordDate == todayDate && h.Pots.Any(p => p.HardwareId == HardwareId))
				.OrderBy(h => h.MinuteOfDay)
				.Select(h => new
				{
					RecordDate = h.RecordDate,
					MinuteOfDay = h.MinuteOfDay,
					Temp = h.Temp,
					Hum = h.Hum,
					Lux = h.Lux,
					DailyLuxHours = h.DailyLuxHours,
					Pot = h.Pots.FirstOrDefault(p => p.HardwareId == HardwareId)
				})
				.ToListAsync();

			chartData = history.Select(h => new PotChartPoint(
				Timestamp: h.RecordDate.ToDateTime(TimeOnly.FromTimeSpan(TimeSpan.FromMinutes(h.MinuteOfDay))).ToLocalTime(),
				HubTemp: h.Temp,
				HubHum: h.Hum,
				HubLux: h.Lux,
				Moisture: h.Pot?.Moisture ?? 0,
				TargetMoisture: h.Pot?.Target ?? 0,
				DailyLuxHours: h.DailyLuxHours
			)).ToList();
            
			Console.WriteLine($"Завантажено {chartData.Count} точок даних для порту {HardwareId}");
		}
		catch (Exception ex)
		{
			Console.WriteLine($"Помилка завантаження статистики: {ex.Message}");
			chartData = new List<PotChartPoint>();
		}
	}
}